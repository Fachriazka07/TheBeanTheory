  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "zIndex": {
    "base": 0,
    "above": 10,
    "sticky": 100,
    "overlay": 200,
    "max": 999
