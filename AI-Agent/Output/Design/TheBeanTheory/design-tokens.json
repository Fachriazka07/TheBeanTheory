{
  "color": {
    "charcoal":    { "value": "#1A1A1A", "usage": "Primary text, headings, hero bg" },
    "espresso":    { "value": "#2C1810", "usage": "Brand accent, CTA hover" },
    "roast":       { "value": "#6B4226", "usage": "Warm highlights, badges, links" },
    "mocha":       { "value": "#8B6F4E", "usage": "Secondary accent, borders" },
    "cream":       { "value": "#F5F0EB", "usage": "Main background" },
    "off-white":   { "value": "#FAFAF7", "usage": "Card surfaces, alt sections" },
    "stone":       { "value": "#9B9590", "usage": "Meta text, captions" },
    "matte-black": { "value": "#111111", "usage": "Hero overlay, dark sections" },
    "white":       { "value": "#FFFFFF", "usage": "Text on dark bg" },
    "error":       { "value": "#C53030", "usage": "Error, sold out badge" },
    "success":     { "value": "#38654A", "usage": "Ready/in-stock" }
  },
  "typography": {
    "fontFamily": {
      "heading": "Playfair Display, Georgia, Times, serif",
      "body": "DM Sans, system-ui, -apple-system, sans-serif",
      "mono": "DM Mono, monospace"
    },
    "fontSize": {
      "display": "4.768rem",
      "h1": "3.815rem",
      "h2": "3.052rem",
      "h3": "2.441rem",
      "h4": "1.953rem",
      "h5": "1.563rem",
      "body-lg": "1.25rem",
      "body": "1rem",
      "body-sm": "0.875rem",
      "caption": "0.75rem"
    },
    "lineHeight": {
      "tight": 1.1,
      "snug": 1.25,
      "normal": 1.5,
      "relaxed": 1.7
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    }
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.5rem",
    "6": "2rem",
    "8": "3rem",
    "10": "4rem",
    "12": "5rem",
    "16": "8rem",
    "20": "10rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "1rem",
    "full": "9999px"
