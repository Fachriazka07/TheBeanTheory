  },
  "transition": {
    "fast": "150ms ease",
    "base": "300ms ease",
    "slow": "500ms cubic-bezier(0.16, 1, 0.3, 1)",
    "smooth": "800ms cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "container": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1440px"
